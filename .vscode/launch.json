{
  "version": "0.2.0",
  "configurations": [


    {
      "type": "node",
      "request": "launch",
      "name": "🧩 Debug Jest (tous les tests)",
      "program": "${workspaceFolder}/node_modules/jest/bin/jest.js",
      "args": [
        "--runInBand",
        "--detectOpenHandles",
        "--colors"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "env": {
        "NODE_ENV": "test"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "🧠 Debug Jest (commandes seulement)",
      "program": "${workspaceFolder}/node_modules/jest/bin/jest.js",
      "args": [
        "commandes",
        "--runInBand",
        "--detectOpenHandles",
        "--colors"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "env": {
        "NODE_ENV": "test"
      }
    }
  ]
}
